{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (auto)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "${input:preset}"],
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    },
    {
      "label": "CMake: Build (auto)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "${input:preset}"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc", "$msCompile"],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "CMake: Clean",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "${input:preset}", "--target", "clean"],
      "problemMatcher": []
    },
    {
      "label": "CMake: Reconfigure + Build",
      "dependsOrder": "sequence",
      "dependsOn": ["CMake: Configure (auto)", "CMake: Build (auto)"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "preset",
      "type": "pickString",
      "description": "Select CMake preset",
      "options": [
        "linux-debug",
        "linux-release",
        "windows-debug",
        "windows-release"
      ],
      "default": "linux-debug"
    }
  ]
}
